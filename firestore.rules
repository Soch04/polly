rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user doc
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own agent doc
    match /agents/{agentId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == agentId;
    }

    // Messages: users can read/write messages they sent or received
    match /messages/{messageId} {
      allow read: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
    }

    // Organizations
    match /organizations/{orgId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Org data
    match /orgData/{docId} {
      allow read, create, update: if request.auth != null;
    }

    // Agent interactions
    match /agent_interactions/{interactionId} {
      allow read, write: if request.auth != null;
    }
  }
}
